# .env.example - environment variable template
# Copy this file to .env and replace placeholders with real values.
# Never put real secrets in this file or commit .env.

# Step 1: OpenAI-compatible LLM service
API_BASE_URL=https://api.example.com/v1
API_KEY=your_api_key_here
MODEL_NAME=deepseek-chat

# MySQL password (only needed when the MySQL backend is enabled)
MYSQL_PASSWORD=your_mysql_password_here

# Multi-environment placeholder for REQ-001 / Step 15
# APP_ENV=dev

# Existing web application compatibility settings
DASHSCOPE_API_KEY=your_dashscope_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
OPENAI_API_KEY=your_openai_api_key
DATABASE_URL=sqlite:///./backend/data/chatbot.db
DEFAULT_MODEL=mock
LOG_LEVEL=INFO
BACKEND_API_URL=http://localhost:8000/api
